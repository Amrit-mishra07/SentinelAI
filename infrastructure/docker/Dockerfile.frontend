FROM node:20-alpine AS builder

WORKDIR /app

COPY apps/aipcsr-web/package*.json ./

RUN npm ci

COPY apps/aipcsr-web/ .

RUN npm run build

FROM node:20-alpine

WORKDIR /app

COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/node_modules ./node_modules
COPY apps/aipcsr-web/package.json .

EXPOSE 3000

CMD ["npm", "start"]
